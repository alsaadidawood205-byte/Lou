-- 1. تبويب البانق (كما هو)
local BangTab = Window:CreateTab("البانق 🔥", 4483362458)

BangTab:CreateInput({
   Name = "اسم الضحية",
   PlaceholderText = "اكتب اسم اللاعب...",
   RemoveTextAfterFocusLost = false,
   Callback = function(text)
      local searchText = text:lower()
      for _, p in pairs(Players:GetPlayers()) do
         if p.Name:lower():find(searchText) and p ~= lp then
            foundPlayer = p
            Rayfield:Notify({ Title = "MAITHAM HUB", Content = "تم تحديد الضحية: " .. p.Name, Duration = 3 })
            return
         end
      end
   end,
})

BangTab:CreateToggle({
   Name = "تفعيل المص (FaceSit)",
   CurrentValue = false,
   Callback = function(value)
      if value and not foundPlayer then
         Rayfield:Notify({ Title = "خطأ", Content = "اختر ضحية أولاً!", Duration = 3 })
         return
      end
      faceSitEnabled = value
      bangEnabled = false
      bangTarget = value and foundPlayer or nil
      if not value then resetVel() end
   end,
})

BangTab:CreateToggle({
   Name = "تفعيل الاغتصاب (Bang)",
   CurrentValue = false,
   Callback = function(value)
      if value and not foundPlayer then
         Rayfield:Notify({ Title = "خطأ", Content = "اختر ضحية أولاً!", Duration = 3 })
         return
      end
      bangEnabled = value
      faceSitEnabled = false
      bangTarget = value and foundPlayer or nil
      if not value then resetVel() end
   end,
})

BangTab:CreateButton({
   Name = "إيقاف كل حركات البانق",
   Callback = function()
      faceSitEnabled = false
      bangEnabled = false
      bangTarget = nil
      resetVel()
      Rayfield:Notify({ Title = "MAITHAM HUB", Content = "تم الإيقاف بنجاح", Duration = 3 })
   end,
})

