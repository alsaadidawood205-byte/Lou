-- [ نظام الـ RP Name & Bio الأصلي ]
-- ═══════════════════════════════════════
pcall(function()
    local RE = ReplicatedStorage:WaitForChild("RE", 2)
    if RE then
        local NameTextEvent = RE:WaitForChild("1RPNam1eTex1t", 2)
        local NameColorEvent = RE:WaitForChild("1RPNam1eColo1r", 2)
        
        local function fireEvent(event, ...)
            if event then event:FireServer(...) end
        end
        
        -- تعيين النصوص الأصلية باسمك
        fireEvent(NameTextEvent, "RolePlayName", "المطور ميثم M2")
        fireEvent(NameTextEvent, "RolePlayBio", "DEVELOPER - MAITHAM M2")
        
        -- نظام الألوان المتحركة (RGB)
        task.spawn(function()
            local hue = 0
            while true do
                hue = (hue + 0.01) % 1
                local color = Color3.fromHSV(hue, 1, 1)
                pcall(function()
                    fireEvent(NameColorEvent, "PickingRPNameColor", color)
                    fireEvent(NameColorEvent, "PickingRPBioColor", color)
                end)
                task.wait(0.05)
            end
        end)
    end
end)

-- ═══════════════════════════════════════
-- المتغيرات العامة للبانق
-- ═══════════════════════════════════════
local foundPlayer = nil
local faceSitEnabled = false
local bangEnabled = false
local bangTarget = nil

local function resetVel()
    pcall(function()
        if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            lp.Character.HumanoidRootPart.Velocity = Vector3.zero
            if lp.Character:FindFirstChild("Humanoid") then
                lp.Character.Humanoid.Sit = false
            end
        end
    end)
end

RunService.Heartbeat:Connect(function()
    pcall(function()
        if (faceSitEnabled or bangEnabled) and bangTarget and bangTarget.Character then
            local targetChar = bangTarget.Character
            if not targetChar:FindFirstChild("HumanoidRootPart") then return end
            local hrp = lp.Character.HumanoidRootPart
            local move = math.sin(tick() * 150) * 1.5
            hrp.Velocity = Vector3.zero
            if faceSitEnabled and targetChar:FindFirstChild("Head") then
                lp.Character.Humanoid.Sit = true
                hrp.CFrame = targetChar.Head.CFrame * CFrame.new(0, 0.2, -0.5 + move) * CFrame.Angles(0, math.rad(180), 0)
            elseif bangEnabled then
                lp.Character.Humanoid.Sit = false
                hrp.CFrame = targetChar.HumanoidRootPart.CFrame * CFrame.new(0, 0.5, 1.1 + move)
            end
        end
    end)
end)

