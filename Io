-- [[ أنيميشن التحميل المتزامن ]] --

local loadingTime = 4 -- مدة التحميل بالثواني

task.spawn(function()
    -- استخدام TweenService لضمان التزامن المثالي
    local tweenInfo = TweenInfo.new(loadingTime, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out)
    
    local tweenH = TweenService:Create(HorizontalBar, tweenInfo, {Size = UDim2.new(1, 0, 1, 0)})
    local tweenV = TweenService:Create(VerticalBar, tweenInfo, {Size = UDim2.new(1, 0, 1, 0)})
    
    tweenH:Play()
    tweenV:Play()
    
    -- تحديث النسبة المئوية يدوياً ليتناسب مع التوين
    local l_start = os.clock()
    while os.clock() - l_start < loadingTime do
        local progress = math.floor(((os.clock() - l_start) / loadingTime) * 100)
        if progress > 100 then progress = 100 end
        PercentLabel.Text = progress .. "%"
        task.wait()
    end
    PercentLabel.Text = "100%"
    
    -- انتهاء التحميل، إخفاء شاشة التحميل فوراً
    local fadeOutInfo = TweenInfo.new(0.5, Enum.EasingStyle.Linear)
    local fadeOut = TweenService:Create(CentralModal, fadeOutInfo, {BackgroundTransparency = 1, Size = UDim2.new(0, 0, 0, 0)})
    fadeOut:Play()
    
    -- إخفاء النصوص والأشرطة بالداخل
    for _, child in pairs(CentralModal:GetDescendants()) do
        if child:IsA("TextLabel") then
            TweenService:Create(child, fadeOutInfo, {TextTransparency = 1}):Play()
        elseif child:IsA("Frame") then
            TweenService:Create(child, fadeOutInfo, {BackgroundTransparency = 1}):Play()
        end
    end
    
    task.wait(0.5)
    BackgroundFrame:Destroy() -- حذف شاشة التحميل
    
    -- تشغيل السكربت مباشرة
    MainContent.Visible = true
    
    -- تأثير اختفاء الرسالة الزجاجية بعد 6 ثواني
    task.wait(6)
    local glassFade = TweenInfo.new(1.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    TweenService:Create(GlassMsg, glassFade, {BackgroundTransparency = 1, Position = UDim2.new(0.5, -160, 0.4, -35)}):Play()
    TweenService:Create(MsgLabel, glassFade, {TextTransparency = 1}):Play()
    task.wait(1.5)
    GlassMsg:Destroy()
end)

-- [[ ميزات الخلفية المحرك الرئيسي ]] --

-- تحديث الـ FPS والوقت
RunService.RenderStepped:Connect(function()
    if MainContent.Visible then
        local fps = math.floor(1 / RunService.RenderStepped:Wait())
        local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        local diff = os.time() - startTime
        local h, m, s = math.floor(diff/3600), math.floor((diff%3600)/60), diff%60
        StatsLabel.Text = string.format("FPS: %d | Ping: %dms\nUptime: %02d:%02d:%02d", fps, ping, h, m, s)
    end
end)

