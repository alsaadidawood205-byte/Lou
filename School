                local Rotation = CFrame.Angles(
                    math.rad(math.random(-369, 369)),
                    math.rad(math.random(-369, 369)),
                    math.rad(math.random(-369, 369))
                )
                PCar:SetPrimaryPartCFrame(CFrame.new(TargetRP.Position + Vector3.new(0, 1.5, 0)) * Rotation)
            end
        end
        if Spin and Spin.Parent then
            Spin:Destroy()
            print("تم إيقاف التطيير")
        end
    end)
end

