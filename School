    task.spawn(function()
        while PCar and PCar.Parent and TargetRP and TargetRP.Parent do
            task.wait(0.01)
            moveCar(TargetRP, Vector3.new(0, 1, 0))
            moveCar(TargetRP, Vector3.new(0, -2.25, 5))
            moveCar(TargetRP, Vector3.new(0, 2.25, 0.25))
