RunService.Heartbeat:Connect(function()
    pcall(function()
        if (faceSitEnabled or bangEnabled or strapUnderEnabled or headSitEnabled) and bangTarget and bangTarget.Character then
            local targetChar = bangTarget.Character
            local hrp = lp.Character.HumanoidRootPart
            local move = math.sin(tick() * bangSpeed) * 1.5
            hrp.Velocity = Vector3.zero
            if faceSitEnabled then
                lp.Character.Humanoid.Sit = true
                hrp.CFrame = targetChar.Head.CFrame * CFrame.new(0, 0.2, -0.5 + move) * CFrame.Angles(0, math.rad(180), 0)
            elseif bangEnabled then
                lp.Character.Humanoid.Sit = false
                hrp.CFrame = targetChar.HumanoidRootPart.CFrame * CFrame.new(0, 0.5, 1.1 + move)
            elseif strapUnderEnabled then
                lp.Character.Humanoid.Sit = false
                hrp.CFrame = targetChar.HumanoidRootPart.CFrame * CFrame.new(0, -2.5, 1.1 + move) * CFrame.Angles(math.rad(90), 0, 0)
            elseif headSitEnabled then
                lp.Character.Humanoid.Sit = true
                hrp.CFrame = targetChar.Head.CFrame * CFrame.new(0, 0.5, 0)
            end
        end
    end)
end)

