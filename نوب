local PlayerList = {}

local function AddLog(message, color)
    local logLabel = Instance.new("TextLabel")
    logLabel.Size = UDim2.new(1, 0, 0, 16)
    logLabel.BackgroundTransparency = 1
    logLabel.Text = message
    logLabel.TextColor3 = color or Color3.fromRGB(220, 220, 220)
    logLabel.TextSize = 9
    logLabel.Font = Enum.Font.Gotham
    logLabel.TextXAlignment = Enum.TextXAlignment.Left
    logLabel.Parent = LogScroll
    
    -- تأثير ظهور بسيط
    logLabel.TextTransparency = 1
    TweenService:Create(logLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()
    
    task.wait(0.05)
    LogScroll.CanvasPosition = Vector2.new(0, LogScroll.CanvasSize.Y.Offset)
end

local function UpdateOnlineCount()
    local count = #Players:GetPlayers()
    OnlineCount.Text = "📊 " .. count
end

-- تسجيل الدخول
Players.PlayerAdded:Connect(function(player)
    if player ~= LocalPlayer then
        AddLog("➕ " .. player.Name .. " دخل", Color3.fromRGB(100, 255, 100))
    end
    UpdateOnlineCount()
end)

-- تسجيل الخروج
Players.PlayerRemoving:Connect(function(player)
    AddLog("➖ " .. player.Name .. " خرج", Color3.fromRGB(255, 100, 100))
    UpdateOnlineCount()
end)

-- تسجيل اللاعبين الموجودين عند التشغيل
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        table.insert(PlayerList, player.Name)
        AddLog("➕ " .. player.Name .. " دخل", Color3.fromRGB(100, 255, 100))
    end
end

