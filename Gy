-- زر تحديث القائمة (باستخدام pcall لتجنب الأخطاء)
TrollTab:AddButton({
    Name = "تحديث قائمة اللاعبين",
    Callback = function()
        local newList = getPlayerList()
        if killDropdown and newList then
            -- محاولة تحديث القائمة بالطريقة المناسبة للمكتبة
            local success, err = pcall(function()
                if killDropdown.SetOptions then
                    killDropdown:SetOptions(newList)
                elseif killDropdown.Set then
                    killDropdown:Set(newList)
                elseif killDropdown.Refresh then
                    killDropdown:Refresh(newList)
                else
                    warn("لا يمكن تحديث القائمة، المكتبة لا تدعم هذه الميزة")
                end
            end)
            if not success then
                warn("فشل تحديث القائمة: " .. tostring(err))
            end
            -- إعادة تعيين الاختيار إذا لم يعد اللاعب موجودًا
            if selectedPlayerName and not Players:FindFirstChild(selectedPlayerName) then
                selectedPlayerName = nil
                getgenv().Target = nil
                if killDropdown.SetValue then
                    pcall(function() killDropdown:SetValue("") end)
                end
                print("تم إعادة تعيين الاختيار، اللاعب غير موجود.")
            end
        else
            print("خطأ: القائمة غير موجودة.")
        end
    end
})

