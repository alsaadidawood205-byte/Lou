-- قسم الجلوس على الرأس
local HeadsitSection = LocalPlayerTab:AddSection({ Name = "الجلوس على الرأس (حصان)" })

local selectedHeadPlayer = nil
local headSitConnection = nil

local headSitDropdown = LocalPlayerTab:AddDropdown({
    Name = "اختر لاعباً",
    Options = getPlayerList(),
    Default = "",
    Callback = function(value)
        selectedHeadPlayer = value
    end
})

LocalPlayerTab:AddToggle({
    Name = "الجلوس على الرأس (حصان)",
    Default = false,
    Callback = function(bool)
        if not selectedHeadPlayer or selectedHeadPlayer == "" then
            warn("لم يتم اختيار لاعب للجلوس على رأسه!")
            return
        end
        local targetPlayer = Players:FindFirstChild(selectedHeadPlayer)
        if bool then
            if targetPlayer and targetPlayer.Character then
                local char = LocalPlayer.Character
                if not char then return end
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                local rootPart = char:FindFirstChild("HumanoidRootPart")
                if not humanoid or not rootPart then return end
                humanoid.Sit = true
                if headSitConnection then headSitConnection:Disconnect() end
                headSitConnection = RunService.Heartbeat:Connect(function()
                    if targetPlayer.Character and targetPlayer.Character:FindFirstChild("Head") and humanoid.Sit then
                        local targetHead = targetPlayer.Character.Head
                        rootPart.CFrame = targetHead.CFrame * CFrame.Angles(0, 0, 0) * CFrame.new(0, 1.6, 0.4)
                    else
                        if headSitConnection then
                            headSitConnection:Disconnect()
                            headSitConnection = nil
                            humanoid.Sit = false
                        end
                    end
                end)
                print("بدء الجلوس على رأس " .. selectedHeadPlayer)
            else
                warn("اللاعب المختار غير موجود أو ليس لديه شخصية!")
            end
        else
            if headSitConnection then
                headSitConnection:Disconnect()
                headSitConnection = nil
            end
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if humanoid then humanoid.Sit = false end
            end
            print("إيقاف الجلوس على الرأس")
        end
    end
})

